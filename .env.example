# ──────────────────────────────────────────────────────────────────────────────
# Variables de entorno — FinanceBot RAG API
# ──────────────────────────────────────────────────────────────────────────────
# Copiá este archivo como .env y completá los valores reales.
# NUNCA commitees el archivo .env a git.

# ── Google Gemini ─────────────────────────────────────────────────────────────
# Obtené tu API key GRATIS en: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Modelo a utilizar
# Opciones: gemini-2.0-flash | gemini-1.5-flash | gemini-1.5-pro
GEMINI_MODEL=gemini-2.0-flash

# Máximo de tokens en la respuesta del LLM
MAX_TOKENS=2048

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME="FinanceBot — Asistente Financiero RAG"
APP_VERSION="1.0.0"
DEBUG=false

# ── RAG / Chunking ────────────────────────────────────────────────────────────
# Tamaño de cada fragmento de texto (en caracteres)
CHUNK_SIZE=1000
# Superposición entre fragmentos para no perder contexto en los bordes
CHUNK_OVERLAP=200
# Número de fragmentos a recuperar por consulta
RETRIEVER_K=4

# ── Pinecone (vector store) ─────────────────────────────────────────────────
# Obtené tu API key GRATIS en: https://app.pinecone.io
PINECONE_API_KEY=your-pinecone-api-key-here
# Nombre del índice (se crea automáticamente al iniciar si no existe)
PINECONE_INDEX_NAME=financebot-rag
PINECONE_NAMESPACE=financial_docs

# ── Embeddings ────────────────────────────────────────────────────────────────
# Modelo local de sentence-transformers (~90MB, no requiere API key adicional)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
